# Required for AI-powered ebook generation
ANTHROPIC_API_KEY=sk-ant-...

# Required for cover image generation
REPLICATE_API_TOKEN=r8_...

# Data directory for generated ebooks (default: /tmp/ebook-gen-data)
DATA_DIR=/data

# Auto-book daily pipeline
AUTO_BOOK_SECRET=your-secret-here
RESEND_API_KEY=re_...
TO_EMAIL=mail@bjoernpuls.com
FROM_EMAIL=ebook-gen <send@herzschlag-der-erde.de>
DOMAIN=ebookgenerator.puls.io

# Server config
PORT=3000
NODE_ENV=production

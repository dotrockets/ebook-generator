{
  "name": "@ebook-gen/core",
  "version": "0.1.0",
  "description": "Core engine for generating beautiful ebooks from Markdown — PDF, EPUB, DOCX",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist",
    "templates",
    "fonts"
  ],
  "dependencies": {
    "execa": "^9.5.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "replicate": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "replicate": {
      "optional": true
    }
  }
}
